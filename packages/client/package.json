{
	"name": "@joaosczip/outy-client",
	"version": "0.0.1",
	"description": "Outbox pattern client — ORM-agnostic adapter-based API for creating transactional outbox events",
	"main": "dist/src/index.js",
	"types": "dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"default": "./dist/src/index.js"
		},
		"./prisma": {
			"types": "./dist/src/adapters/prisma-adapter.d.ts",
			"default": "./dist/src/adapters/prisma-adapter.js"
		},
		"./sequelize": {
			"types": "./dist/src/adapters/sequelize-adapter.d.ts",
			"default": "./dist/src/adapters/sequelize-adapter.js"
		}
	},
	"license": "MIT",
	"author": "João Sczip",
	"repository": {
		"type": "git",
		"url": "https://github.com/joaosczip/outbox-reader"
	},
	"homepage": "https://github.com/joaosczip/outbox-reader#readme",
	"bugs": {
		"url": "https://github.com/joaosczip/outbox-reader/issues"
	},
	"keywords": ["outbox", "transactional-outbox", "prisma", "sequelize", "postgres", "client"],
	"engines": {
		"bun": ">=1.2.0"
	},
	"files": ["dist/src", "README.md", "LICENSE"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -b",
		"lint": "biome check src/",
		"test": "bun test",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"@prisma/client": ">=5.0.0",
		"sequelize": ">=6.0.0"
	},
	"peerDependenciesMeta": {
		"@prisma/client": {
			"optional": true
		},
		"sequelize": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^20.3.1",
		"@types/pg": "^8.x",
		"pg": "^8.x"
	}
}
