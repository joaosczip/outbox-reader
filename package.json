{
	"name": "outbox-reader-workspace",
	"version": "1.0.0",
	"private": true,
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "bun run --filter '*' build",
		"test": "bun run --filter '*' test",
		"lint": "biome check packages/",
		"start": "bun run --filter '@outbox-reader/core' start",
		"reprocess-failed-events": "bun run --filter '@outbox-reader/core' reprocess-failed-events",
		"check-pending-events": "bun run --filter '@outbox-reader/core' check-pending-events",
		"schema:generate": "bun run --filter '@joaosczip/outy-cli' generate"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"typescript": "^5.1.3"
	}
}
