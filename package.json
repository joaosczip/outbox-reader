{
	"name": "outbox-reader",
	"version": "1.0.0",
	"description": "Outbox pattern implementation with PostgreSQL WAL and NATS JetStream",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"author": "joao.sczip@hotmail.com",
	"private": true,
	"license": "UNLICENSED",
	"engines": {
		"bun": ">=1.2.0"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -b",
		"start": "bun --watch src/app.ts",
		"reprocess-failed-events": "bun src/cronjobs/reprocess-failed-events.ts",
		"check-pending-events": "bun src/cronjobs/check-pending-events.ts",
		"db:generate": "npx prisma generate --schema=./database/prisma/schema.prisma",
		"db:migrate:dev": "npx prisma migrate dev --schema=./database/prisma/schema.prisma",
		"schema:generate": "bun src/cli/generate-schema.ts",
		"lint": "biome check src/",
		"test": "bun test"
	},
	"bin": {
		"outbox-schema": "./bin/outbox-schema.js"
	},
	"dependencies": {
		"@nats-io/jetstream": "^3.0.0-38",
		"@paralleldrive/cuid2": "^2.2.2",
		"commander": "^13.1.0",
		"dotenv-config": "^0.1.1",
		"exponential-backoff": "^3.1.2",
		"luxon": "^3.5.0",
		"nats": "^2.29.1",
		"pg": "^8.14.0",
		"pg-logical-replication": "^2.0.7",
		"pino": "^9.6.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/commander": "^2.12.0",
		"@types/luxon": "^3.4.2",
		"@types/node": "^20.3.1",
		"@types/pg": "^8.11.11",
		"@biomejs/biome": "^1.9.4",
		"typescript": "^5.1.3"
	}
}
