DATABASE_URL=postgres://pg:pg@127.0.0.1:5432/db?replication=database
REPLICATION_SLOT_NAME=outbox_slot

# NATS Configuration
# NATS server URLs (comma-separated for multiple servers)
NATS_SERVERS=nats://localhost:4222
# Connection name for identification in server logs
NATS_CONNECTION_NAME=outbox-reader
# Authentication (optional)
# NATS_USER=username
# NATS_PASSWORD=password
# NATS_TOKEN=token
# Connection settings (optional)
# NATS_MAX_RECONNECT_ATTEMPTS=-1
# NATS_RECONNECT_TIME_WAIT=2000
# NATS_TIMEOUT=20000
# NATS_VERBOSE=false
# NATS_PEDANTIC=false
