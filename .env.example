DATABASE_URL=postgres://pg:pg@127.0.0.1:5432/db?replication=database
REPLICATION_SLOT_NAME=outbox_slot

# NATS Configuration
# Single URL — embed credentials as: nats://user:pass@host:4222
TARGET_NATS_URL=nats://localhost:4222

# Health check server port (default: 4599)
PORT=4599

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
